{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:web",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "OpenClaw",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "dialog": {
        "open": true
      },
      "shell": {
        "open": true
      }
    },
    "windows": [
      {
        "title": "OpenClaw",
        "width": 1080,
        "height": 760,
        "minWidth": 920,
        "minHeight": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    },
    "bundle": {
      "active": true,
      "targets": [
        "nsis",
        "msi",
        "dmg",
        "appimage",
        "deb",
        "rpm"
      ],
      "identifier": "dev.openclawapp.desktop",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "resources": [
        "../resources/skills",
        "../resources/bin",
        "../resources/kernel-meta.json",
        "../resources/kernel.tar"
      ]
    }
  }
}
