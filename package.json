{
  "name": "openclawapp-monorepo",
  "private": true,
  "license": "MIT",
  "description": "OpenClaw desktop/mobile/server monorepo",
  "workspaces": [
    "apps/desktop",
    "apps/mobile",
    "apps/server",
    "packages/*"
  ],
  "scripts": {
    "dev:desktop": "npm --prefix apps/desktop run dev",
    "build:desktop": "npm --prefix apps/desktop run dist",
    "lint:desktop": "npm --prefix apps/desktop run build:web"
  }
}
