{
  "name": "openclawapp-workspace",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "OpenClaw workspace root",
  "type": "module",
  "workspaces": [
    "desktop",
    "mobile",
    "server",
    "packages/protocol",
    "mobile-rn"
  ],
  "scripts": {
    "desktop:dev": "npm --prefix desktop run dev",
    "desktop:dev:web": "npm --prefix desktop run dev:web",
    "desktop:build:web": "npm --prefix desktop run build:web",
    "desktop:prepare:kernel": "npm --prefix desktop run prepare:kernel",
    "desktop:dist": "npm --prefix desktop run dist",
    "desktop:dist:mac": "npm --prefix desktop run dist:mac",
    "desktop:dist:mac:tauri": "npm --prefix desktop run dist:mac:tauri",
    "desktop:dist:win": "npm --prefix desktop run dist:win",
    "desktop:dist:win:ci": "npm --prefix desktop run dist:win:ci",
    "desktop:dist:linux": "npm --prefix desktop run dist:linux",
    "desktop:dist:linux:ci": "npm --prefix desktop run dist:linux:ci",
    "desktop:dist:linux:appimage": "npm --prefix desktop run dist:linux:appimage",
    "mobile:dev": "npm --prefix mobile run dev",
    "mobile:build": "npm --prefix mobile run build",
    "server:dev": "npm --prefix server run dev",
    "server:start": "npm --prefix server run start",
    "typecheck": "npm run -ws typecheck",
    "dev": "npm run desktop:dev",
    "dev:web": "npm run desktop:dev:web",
    "build:web": "npm run desktop:build:web",
    "prepare:kernel": "npm run desktop:prepare:kernel",
    "dist": "npm run desktop:dist",
    "dist:mac": "npm run desktop:dist:mac",
    "dist:mac:tauri": "npm run desktop:dist:mac:tauri",
    "dist:win": "npm run desktop:dist:win",
    "dist:win:ci": "npm run desktop:dist:win:ci",
    "dist:linux": "npm run desktop:dist:linux",
    "dist:linux:ci": "npm run desktop:dist:linux:ci",
    "dist:linux:appimage": "npm run desktop:dist:linux:appimage",
    "mobile-rn:start": "npm --prefix mobile-rn run start",
    "mobile-rn:ios": "npm --prefix mobile-rn run ios",
    "mobile-rn:android": "npm --prefix mobile-rn run android",
    "mobile-rn:web": "npm --prefix mobile-rn run web",
    "mobile-rn:typecheck": "npm --prefix mobile-rn run typecheck"
  },
  "devDependencies": {
    "@esbuild/win32-x64": "^0.21.5",
    "@rollup/rollup-win32-x64-msvc": "^4.52.5",
    "@tauri-apps/cli-win32-x64-msvc": "^1.6.2"
  }
}
