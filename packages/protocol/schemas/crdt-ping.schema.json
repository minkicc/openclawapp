{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclawapp.dev/schemas/crdt-ping.schema.json",
  "title": "OpenClawCrdtPing",
  "type": "object",
  "required": ["id", "sentAt"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048
    },
    "sentAt": {
      "type": "integer",
      "minimum": 0
    }
  },
  "additionalProperties": false
}
