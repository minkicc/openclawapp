{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclawapp.dev/schemas/payload-task-progress.schema.json",
  "title": "TaskProgressPayload",
  "type": "object",
  "required": ["taskId", "stage", "percent"],
  "properties": {
    "taskId": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128
    },
    "stage": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "percent": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "detail": {
      "type": "string",
      "maxLength": 20000
    }
  },
  "additionalProperties": false
}
