{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclawapp.dev/schemas/crdt-sync-state.schema.json",
  "title": "OpenClawCrdtSyncState",
  "type": "object",
  "required": ["conversationId", "versionVector", "frontier", "ts"],
  "properties": {
    "conversationId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048
    },
    "versionVector": {
      "$ref": "#/$defs/versionVector"
    },
    "frontier": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      },
      "uniqueItems": true
    },
    "ts": {
      "type": "integer",
      "minimum": 0
    }
  },
  "additionalProperties": false,
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048
    },
    "versionVector": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/$defs/nonEmptyString"
      },
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    }
  }
}
