{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclawapp.dev/schemas/payload-task-result.schema.json",
  "title": "TaskResultPayload",
  "type": "object",
  "required": ["taskId", "status"],
  "properties": {
    "taskId": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128
    },
    "status": {
      "type": "string",
      "enum": ["success", "error", "canceled"]
    },
    "result": {
      "type": ["object", "array", "string", "number", "boolean", "null"]
    },
    "error": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
