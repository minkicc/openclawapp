{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": {
      "@openclaw/pair-sdk": ["../pair-sdk/src/index.ts"],
      "@openclaw/protocol": ["../protocol/src/index.ts"]
    },
    "noEmit": true
  },
  "include": ["src/**/*.ts"]
}
