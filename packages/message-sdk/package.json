{
  "name": "@openclaw/message-sdk",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "OpenClaw business message SDK built on top of @openclaw/pair-sdk",
  "files": [
    "src",
    "dist",
    "README.md"
