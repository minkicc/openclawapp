{
  "name": "@openclaw/pair-sdk",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Pairing/discovery/control-plane SDK for OpenClaw-compatible desktop/mobile/server clients",
  "files": [
    "src",
    "dist",
    "README.md"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./web": "./src/web.ts",
    "./peer": "./src/peer.ts",
    "./app": "./src/app.ts",
    "./runtime": "./src/runtime.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@noble/hashes": "^1.8.0",
    "@scure/base": "^1.2.6",
    "tweetnacl": "^1.0.3"
  },
