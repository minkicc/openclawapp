OPENCLAW_SERVER_IMAGE=openclaw/server:latest
OPENCLAW_SERVER_GOPROXY=https://proxy.golang.org,direct
OPENCLAW_SERVER_STORE_BACKEND=redis
OPENCLAW_SERVER_REDIS_URL=redis://redis:6379
OPENCLAW_SERVER_REDIS_KEY_PREFIX=openclaw:server
OPENCLAW_SERVER_V2_ICE_SERVERS_JSON=[{"urls":["stun:stun.cloudflare.com:3478","stun:stun.l.google.com:19302"]}]
OPENCLAW_SERVER_V2_ICE_TTL_SECONDS=600
TROJAN_GO_PORT=8443
